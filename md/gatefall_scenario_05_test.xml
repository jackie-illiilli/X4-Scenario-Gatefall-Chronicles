<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Gatefall_Scenario_05" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <cue name="Start" namespace="this" module="gatefall_scenario_05">
      <conditions><event_cue_signalled cue="md.Setup.Start" /></conditions>
      <actions>
        <set_value name="md.GenericMissions.Manager.$Disabled" exact="true" /><set_value name="$MissionCue" exact="namespace" /><set_value name="$ScenarioEnded" exact="false" /><set_value name="$ProductionCount" exact="0" /><set_value name="$ProductionBusy" exact="false" />
        <find_sector name="$Choice" macro="macro.gatefall_scenario_05_sector_macro" /><find_sector name="$ArgonPrime" macro="macro.gatefall_scenario_05_argon_prime_sector_macro" /><find_sector name="$Faith" macro="macro.gatefall_scenario_05_faith_sector_macro" /><find_sector name="$Nopileos" macro="macro.gatefall_scenario_05_nopileos_sector_macro" />
        <create_position name="$Phase1Target" space="$Choice" x="0" y="0" z="70km" /><create_position name="$PrimeTarget" space="$ArgonPrime" x="0" y="0" z="80km" /><create_position name="$FaithTarget" space="$Faith" x="0" y="0" z="70km" /><create_position name="$AnchorTarget" space="$Nopileos" x="0" y="0" z="60km" />
        <generate_loadout result="$PlayerLoadout" macro="player.ship.macro" faction="faction.xenon" level="1.0" variation="0" /><do_if value="$PlayerLoadout.count"><apply_loadout object="player.ship" loadout="$PlayerLoadout.{1}" /></do_if><set_object_min_hull object="player.ship" exact="1" />
        <set_faction_relation faction="faction.player" otherfaction="faction.argon" value="faction.argon.relation.enemy.min" /><set_faction_relation faction="faction.argon" otherfaction="faction.player" value="faction.argon.relation.enemy.min" />
        <create_group groupname="$ChoiceAssets" /><create_group groupname="$PrimeAssets" /><create_group groupname="$ProducedShips" />
        <create_mission cue="$MissionCue" abortable="false" name="{899903,301}" description="{899903,302}" icon="'briefing_mission_director_01'" difficulty="level.medium" type="missiontype.plot" faction="faction.player"><briefing><objective step="1" action="objective.flyto" object="$Choice" offset="$Phase1Target" radius="8km" text="{899903,311}" /><objective step="2" action="objective.flyto" object="$ArgonPrime" offset="$PrimeTarget" radius="8km" text="{899903,312}" /><objective step="3" action="objective.flyto" object="$Faith" offset="$FaithTarget" radius="8km" text="{899903,313}" /><objective step="4" action="objective.flyto" object="$Nopileos" offset="$AnchorTarget" radius="8km" text="{899903,314}" /></briefing></create_mission>
        <set_objective_from_briefing cue="$MissionCue" step="1" /><show_notification text="{899903,501}" sound="notification_generic" />
        <!-- Representative Phase 1 expedition review: ten destroyers, six carriers/supply ships, three builders and four factories. -->
        <do_all exact="10" counter="$i"><create_position name="$P" space="$Choice" x="if $i mod 2 then -8km else 8km" y="0" z="10km + $i * 8km" /><create_ship name="$Ship" macro="macro.ship_arg_l_destroyer_01_a_macro" sector="$Choice" groupname="$ChoiceAssets" capturable="false"><owner exact="faction.argon" /><pilot><select faction="faction.argon" tags="tag.commander" /></pilot><loadout><level exact="0.7" /></loadout><position value="$P" /></create_ship></do_all>
        <do_all exact="3" counter="$i"><create_position name="$P" space="$Choice" x="-12km" y="0" z="90km + $i * 12km" /><create_ship name="$Ship" macro="macro.ship_arg_xl_carrier_01_a_macro" sector="$Choice" groupname="$ChoiceAssets"><owner exact="faction.argon" /><pilot><select faction="faction.argon" tags="tag.commander" /></pilot><loadout><level exact="0.7" /></loadout><position value="$P" /></create_ship><create_position name="$P2" space="$Choice" x="12km" y="0" z="90km + $i * 12km" /><create_ship name="$Supply" macro="macro.ship_arg_xl_resupplier_01_a_macro" sector="$Choice" groupname="$ChoiceAssets"><owner exact="faction.argon" /><pilot><select faction="faction.argon" tags="tag.commander" /></pilot><loadout><level exact="0.7" /></loadout><position value="$P2" /></create_ship></do_all>
        <signal_cue cue="Phase1Dialogue" />
      </actions>
      <cues>
        <cue name="Phase1Dialogue"><conditions><event_cue_signalled /></conditions><actions><show_notification text="{899903,511}" sound="notification_generic" /></actions><delay exact="8s" /><actions><show_notification text="{899903,512}" sound="notification_generic" /></actions></cue>
        <cue name="Phase1Complete" checkinterval="1s"><conditions><check_value value="player.ship.distanceto.[$Choice,$Phase1Target] lt 8km" /></conditions><actions><destroy_group group="$ChoiceAssets" explosion="false" /><warp object="player.ship" sector="$ArgonPrime"><position x="0" y="0" z="0" /></warp><add_effect object="player.ship.zone" effect="'hq_warpin'" /><set_objective_from_briefing cue="$MissionCue" step="2" /><signal_cue cue="SetupPrime" /></actions></cue>
        <cue name="SetupPrime"><conditions><event_cue_signalled /></conditions><actions>
          <create_position name="$WharfPos" space="$ArgonPrime" x="-35km" y="0" z="25km" /><create_station name="$Wharf" macro="macro.station_gen_factory_base_01_macro" sector="$ArgonPrime" owner="faction.argon" constructionplan="'arg_wharf'" state="componentstate.operational" groupname="$PrimeAssets"><position value="$WharfPos" /></create_station><set_object_name object="$Wharf" name="{899903,31}" />
          <create_position name="$ShipyardPos" space="$ArgonPrime" x="35km" y="0" z="45km" /><create_station name="$Shipyard" macro="macro.station_gen_factory_base_01_macro" sector="$ArgonPrime" owner="faction.argon" constructionplan="'arg_shipyard'" state="componentstate.operational" groupname="$PrimeAssets"><position value="$ShipyardPos" /></create_station><set_object_name object="$Shipyard" name="{899903,32}" />
          <create_position name="$AdminPos" space="$ArgonPrime" x="0" y="0" z="65km" /><create_station name="$Admin" macro="macro.station_gen_factory_base_01_macro" sector="$ArgonPrime" owner="faction.argon" constructionplan="'arg_defence'" state="componentstate.operational" groupname="$PrimeAssets"><position value="$AdminPos" /></create_station><set_object_name object="$Admin" name="{899903,33}" />
          <do_all exact="5" counter="$i"><create_position name="$P" space="$ArgonPrime" x="-60km + $i * 25km" y="0" z="30km + $i * 8km" /><create_ship name="$Builder" macro="macro.ship_arg_xl_builder_01_a_macro" sector="$ArgonPrime" groupname="$PrimeAssets"><owner exact="faction.argon" /><pilot><select faction="faction.argon" tags="tag.commander" /></pilot><loadout><level exact="0.7" /></loadout><position value="$P" /></create_ship></do_all>
          <show_notification text="{899903,521}" sound="notification_generic" />
        </actions></cue>
        <cue name="Phase2PrimeComplete" checkinterval="1s"><conditions><check_value value="player.sector == $ArgonPrime and player.ship.distanceto.[$ArgonPrime,$PrimeTarget] lt 8km" /></conditions><actions><warp object="player.ship" sector="$Faith"><position x="0" y="0" z="0" /></warp><add_effect object="player.ship.zone" effect="'hq_warpin'" /><set_objective_from_briefing cue="$MissionCue" step="3" /><show_notification text="{899903,522}" sound="notification_generic" /></actions></cue>
        <cue name="Phase2FaithComplete" checkinterval="1s"><conditions><check_value value="player.sector == $Faith and player.ship.distanceto.[$Faith,$FaithTarget] lt 8km" /></conditions><actions><warp object="player.ship" sector="$Nopileos"><position x="0" y="0" z="0" /></warp><add_effect object="player.ship.zone" effect="'hq_warpin'" /><set_objective_from_briefing cue="$MissionCue" step="4" /><show_notification text="{899903,531}" sound="notification_generic" /></actions></cue>
        <cue name="Phase3Anchor" checkinterval="1s"><conditions><check_value value="player.sector == $Nopileos and player.ship.distanceto.[$Nopileos,$AnchorTarget] lt 8km" /></conditions><actions>
          <create_ship name="$Beacon" macro="macro.ship_xen_s_scout_01_a_macro" sector="$Nopileos" capturable="false"><owner exact="faction.player" /><loadout><level exact="1.0" /></loadout><position value="$AnchorTarget" /></create_ship><set_object_name object="$Beacon" name="{899903,34}" /><show_notification text="{899903,541}" sound="notification_positive" /><signal_cue cue="DeployFleet" />
        </actions></cue>
        <cue name="DeployFleet"><conditions><event_cue_signalled /></conditions><delay exact="5s" /><actions>
          <create_position name="$CPUPos" space="$Nopileos" object="player.ship" min="10km" max="15km" /><create_ship name="$CPUShip" macro="macro.ship_tfm_xl_carrier_02_b_macro" sector="$Nopileos" capturable="false" commandeerable="false"><owner exact="faction.player" overridenpc="true" /><pilot><select faction="faction.xenon" tags="tag.commander" /></pilot><loadout><level exact="1.0" /></loadout><position value="$CPUPos" /></create_ship><set_object_name object="$CPUShip" name="{899903,21}" /><add_effect object="$CPUShip.zone" effect="'hq_warpin'" /><set_object_min_hull object="$CPUShip" exact="1" />
          <do_all exact="1"><create_position name="$P" space="$Nopileos" object="$CPUShip" min="5km" max="9km" /><create_ship name="$I" macro="macro.ship_xen_xl_carrier_01_a_macro" sector="$Nopileos"><owner exact="faction.player" /><pilot><select faction="faction.xenon" tags="tag.commander" /></pilot><loadout><level exact="1.0" /></loadout><position value="$P" /></create_ship></do_all>
          <do_all exact="2"><create_position name="$P" space="$Nopileos" object="$CPUShip" min="5km" max="9km" /><create_ship name="$K" macro="macro.ship_xen_xl_destroyer_01_a_macro" sector="$Nopileos"><owner exact="faction.player" /><pilot><select faction="faction.xenon" tags="tag.commander" /></pilot><loadout><level exact="1.0" /></loadout><position value="$P" /></create_ship></do_all>
          <do_all exact="5"><create_position name="$P" space="$Nopileos" object="$CPUShip" min="3km" max="7km" /><create_ship name="$PE" macro="macro.ship_xen_m_corvette_02_a_macro" sector="$Nopileos"><owner exact="faction.player" /><pilot><select faction="faction.xenon" tags="tag.pilot" /></pilot><loadout><level exact="1.0" /></loadout><position value="$P" /></create_ship></do_all>
          <do_all exact="10"><create_position name="$P" space="$Nopileos" object="$CPUShip" min="2km" max="6km" /><create_ship name="$F" macro="macro.ship_xen_s_heavyfighter_01_a_macro" sector="$Nopileos"><owner exact="faction.player" /><pilot><select faction="faction.xenon" tags="tag.pilot" /></pilot><loadout><level exact="1.0" /></loadout><position value="$P" /></create_ship></do_all>
          <set_objective cue="$MissionCue" step="5" action="objective.custom" customaction="{899903,315}" text="{899903,315}" updatebriefing="true" /><show_notification text="{899903,551}" sound="notification_generic" /><signal_cue cue="CreateOffers" />
        </actions></cue>
        <cue name="CreateOffers" instantiate="true"><conditions><event_cue_signalled /></conditions><actions><set_value name="$ProductionBusy" exact="false" />
          <create_offer cue="OfferI" name="{899903,201}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,201}" /></briefing></create_offer>
          <create_offer cue="OfferK" name="{899903,202}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,202}" /></briefing></create_offer>
          <create_offer cue="OfferPE" name="{899903,203}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,203}" /></briefing></create_offer>
          <create_offer cue="OfferB" name="{899903,204}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,204}" /></briefing></create_offer>
          <create_offer cue="OfferF" name="{899903,205}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,205}" /></briefing></create_offer>
          <create_offer cue="OfferM" name="{899903,206}" description="{899903,211}" actor="player.computer" faction="faction.player" type="missiontype.plot" difficulty="level.easy" hidden="false" space="player.sector"><briefing><objective step="1" action="objective.custom" customaction="{899903,206}" /></briefing></create_offer>
        </actions></cue>
        <cue name="OfferI"><cues><cue name="AcceptI" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferI" /></conditions><actions><signal_cue_instantly cue="Produce" param="'I'" /></actions></cue></cues></cue>
        <cue name="OfferK"><cues><cue name="AcceptK" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferK" /></conditions><actions><signal_cue_instantly cue="Produce" param="'K'" /></actions></cue></cues></cue>
        <cue name="OfferPE"><cues><cue name="AcceptPE" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferPE" /></conditions><actions><signal_cue_instantly cue="Produce" param="'PE'" /></actions></cue></cues></cue>
        <cue name="OfferB"><cues><cue name="AcceptB" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferB" /></conditions><actions><signal_cue_instantly cue="Produce" param="'B'" /></actions></cue></cues></cue>
        <cue name="OfferF"><cues><cue name="AcceptF" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferF" /></conditions><actions><signal_cue_instantly cue="Produce" param="'F'" /></actions></cue></cues></cue>
        <cue name="OfferM"><cues><cue name="AcceptM" instantiate="true"><conditions><event_object_signalled object="player.computer" param="'accept'" param2="OfferM" /></conditions><actions><signal_cue_instantly cue="Produce" param="'M'" /></actions></cue></cues></cue>
        <cue name="Produce" instantiate="true"><conditions><event_cue_signalled /></conditions><actions><do_if value="not $ProductionBusy"><set_value name="$ProductionBusy" exact="true" /><set_value name="$Selection" exact="event.param" /><remove_offer cue="OfferI" /><remove_offer cue="OfferK" /><remove_offer cue="OfferPE" /><remove_offer cue="OfferB" /><remove_offer cue="OfferF" /><remove_offer cue="OfferM" />
          <do_if value="$Selection == 'I'"><set_value name="$Count" exact="1" /><set_value name="$Macro" exact="macro.ship_xen_xl_carrier_01_a_macro" /></do_if><do_elseif value="$Selection == 'K'"><set_value name="$Count" exact="2" /><set_value name="$Macro" exact="macro.ship_xen_xl_destroyer_01_a_macro" /></do_elseif><do_elseif value="$Selection == 'PE'"><set_value name="$Count" exact="10" /><set_value name="$Macro" exact="macro.ship_xen_m_corvette_02_a_macro" /></do_elseif><do_elseif value="$Selection == 'B'"><set_value name="$Count" exact="10" /><set_value name="$Macro" exact="macro.ship_xen_m_fighter_01_a_macro" /></do_elseif><do_elseif value="$Selection == 'F'"><set_value name="$Count" exact="20" /><set_value name="$Macro" exact="macro.ship_xen_s_heavyfighter_01_a_macro" /></do_elseif><do_else><set_value name="$Count" exact="30" /><set_value name="$Macro" exact="macro.ship_xen_s_fighter_02_a_macro" /></do_else>
          <do_all exact="$Count"><create_position name="$P" space="$Nopileos" object="$CPUShip" min="2km" max="8km" /><create_ship name="$Unit" macro="$Macro" sector="$Nopileos" groupname="$ProducedShips"><owner exact="faction.player" /><pilot><select faction="faction.xenon" tags="tag.pilot" /></pilot><loadout><level exact="1.0" /></loadout><position value="$P" /></create_ship></do_all><set_value name="$ProductionCount" operation="add" exact="1" /><set_objective cue="$MissionCue" step="5" action="objective.custom" customaction="{899903,315}" text="{899903,315}" updatebriefing="true" /><show_notification text="{899903,552}" sound="notification_positive" /><do_if value="$ProductionCount ge 3"><signal_cue cue="MissionComplete" /></do_if><do_else><signal_cue cue="Cooldown" /></do_else></do_if></actions></cue>
        <cue name="Cooldown" instantiate="true"><conditions><event_cue_signalled /></conditions><delay exact="120s" /><actions><signal_cue cue="CreateOffers" /></actions></cue>
        <cue name="MissionComplete"><conditions><event_cue_signalled /></conditions><delay exact="3s" /><actions><set_value name="$ScenarioEnded" exact="true" /><remove_offer cue="OfferI" /><remove_offer cue="OfferK" /><remove_offer cue="OfferPE" /><remove_offer cue="OfferB" /><remove_offer cue="OfferF" /><remove_offer cue="OfferM" /><remove_mission cue="$MissionCue" type="completed" /><show_notification text="{899903,1001}" sound="notification_generic" /><set_value name="$ResultData" exact="table[]" /><set_value name="$ResultData.$PlayerDied" exact="false" /><set_value name="$ResultData.$Score" exact="0" /><add_scenario_stat id="'gatefall_scenario_05_phase4'" name="{899903,1002}" description="{899903,1003}" uivalue="$ProductionCount" score="0" maxscore="1" /><set_userdata name="'gatefall_scenario_05_phase4_completed'" value="1" /></actions><cues><cue name="Finish" ref="md.Gatefall_Lib_Scenario.ScenarioFinished"><param name="ResultData" value="$ResultData" /></cue></cues></cue>
        <cue name="PlayerDestroyed"><conditions><event_object_destroyed object="player.entity" /></conditions><actions><set_value name="$ResultData" exact="table[]" /><set_value name="$ResultData.$PlayerDied" exact="true" /><set_value name="$ResultData.$Score" exact="0" /></actions><cues><cue name="Failed" ref="md.Gatefall_Lib_Scenario.ScenarioFinished"><param name="ResultData" value="$ResultData" /></cue></cues></cue>
      </cues>
    </cue>
  </cues>
</mdscript>
