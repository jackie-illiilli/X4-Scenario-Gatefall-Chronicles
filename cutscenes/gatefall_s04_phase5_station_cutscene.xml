<?xml version="1.0" encoding="utf-8"?>
<cutscene xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="cutscenes.xsd">
  <director key="gatefall_s04_phase5_station_cutscene" />

  <environments>
    <environment_implicit name="scenezone" zone="@auto:target_station" />
    <object_group name="targets">
      <reference object="target_station" />
    </object_group>
  </environments>

  <presentation>
    <actions>
      <sequence name="Main" start="0">
        <shot name="StationSurvey" environment="scenezone" duration="26000">
          <camera_orbit reference="target_station" orient_to="object" interpolation="smooth" cycle="none">
            <begin distance="18000" angle="-18" elevation="7" />
            <end distance="15000" angle="-4" elevation="10" time="22000" />
          </camera_orbit>
        </shot>
      </sequence>
    </actions>
  </presentation>
</cutscene>
